---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Floaters from "../components/Floaters.astro";
import SiteScript from "../components/SiteScript.astro";
import CookieConsent from "../components/CookieConsent.astro";
import AccessibilityWidget from "../components/AccessibilityWidget.astro";
import LeadTab from "../components/LeadTab.astro";

const {
  title = "זברה — הדרך הקלה להלוואה",
  description = "ב'זברה' מתאימים לכם את המימון המדויק: הלוואות לכל מטרה, לבעלי עסקים, וכנגד הרכב — בלי למסור מפתחות. אישור מהיר, פריסה עד 100 תשלומים, כסף בחשבון תוך 24 שעות.",
  image = "/images/zebra.webp",
  type = "website",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
const path = Astro.url.pathname;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "זברה",
  description: "גוף המתווך בין הלווה למלווה להשגת ההלוואה המשתלמת ביותר.",
  url: Astro.site?.toString(),
  logo: new URL("/images/logo.png", Astro.site).toString(),
  slogan: "הדרך הקלה להלוואה",
};
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="nGHlAWCJfmvQeEtayCp3N9QOdr_fzw32Wjkhm0yE8V0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/images/logo.png" />

  <!-- Meta Pixel Code -->
  <script is:inline>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1006480998397707');
    fbq('track', 'PageView');
  </script>
  <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1006480998397707&ev=PageView&noscript=1" alt="" /></noscript>
  <!-- End Meta Pixel Code -->

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="he_IL" />
  <meta name="twitter:card" content="summary_large_image" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Hebrew:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  <slot name="head" />
</head>
<body>
  <Header path={path} />
  <main>
    <slot />
  </main>
  <Footer />
  <Floaters />
  <SiteScript />
  <CookieConsent />
  <AccessibilityWidget />
  <LeadTab />
</body>
</html>
