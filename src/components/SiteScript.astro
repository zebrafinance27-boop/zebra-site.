<script is:inline>
/* =========================================================================
   הגדרות — עדכנו כאן את פרטי הקשר שלכם:
   ========================================================================= */
const CONFIG = {
  phone:    "0545995519",        // מספר טלפון להצגה ולחיוג
  whatsapp: "972545995519",      // מספר WhatsApp בפורמט בינלאומי (972 במקום 0)
  // הלידים נשלחים לכל הכתובות הבאות (אפשר להוסיף/להסיר):
  webhooks: [
    "https://webhooks.pipely.co.il/catch-lead?client_id=2c0a073a-7e10-4ae4-9891-90857db9aea5",
    "https://hook.eu1.make.com/slzneu9bbw0b3rt1yybugtdjr2ledavf"
  ],
  sendToWhatsApp: true,          // לאחר שליחה — להציע המשך ב-WhatsApp עם הפרטים
  // וובהוק נפרד להמלצות (תרחיש Make נפרד). יוחלף בכתובת האמיתית לאחר יצירת התרחיש:
  reviewWebhook: "https://hook.eu1.make.com/cgv8yw9qyor2bsmkwqdw4308ngr6pu8y"
};

/* ----- לכידת פרמטרי UTM וטראקינג (נטענים מכתובת העמוד) ----- */
const tracking = (function(){
  const p = new URLSearchParams(location.search), t = {};
  ["utm_source","utm_medium","utm_campaign","utm_term","utm_content","gclid","fbclid"].forEach(k=>{
    const v = p.get(k); if(v) t[k] = v;
  });
  t.landing_page = location.href;
  t.referrer = document.referrer || "";
  return t;
})();

/* ----- חיווט פרטי קשר ----- */
(function(){
  const tel="tel:"+CONFIG.phone;
  ["hdrPhone","heroCall","footPhone","fabCall","contactCall"].forEach(id=>{const e=document.getElementById(id);if(e)e.href=tel;});
  const pretty=CONFIG.phone.replace(/(\d{3})(\d{3})(\d{0,4})/,"$1-$2-$3");
  const fp=document.getElementById("footPhone");if(fp)fp.lastChild.textContent=pretty;
  const wa="https://wa.me/"+CONFIG.whatsapp;
  ["fabWa","footWa"].forEach(id=>{const e=document.getElementById(id);if(e)e.href=wa;});
})();

/* ----- מנוע השאלון המדורג ----- */
const wizard=document.getElementById("wizard");
const picked={};       // לכל שאלה: {key, question, answer} — עם הטקסט המוצג בפועל
function qText(screen){const t=document.querySelector('[data-screen="'+screen+'"] .q-title');return t?t.textContent.trim():screen;}
function aText(el){const l=el.querySelector(".oc-label");return (l?l.textContent:el.textContent).trim();}
let stack=[];          // היסטוריית מסכים לכפתור "חזרה"
let curPct=25;

const stepLabels={q1:"שאלה 1",q2:"שאלה 2",q3:"שאלה 2",details:"פרטים אחרונים",done:"סיום",no:""};
function setProgress(p){curPct=p;document.getElementById("wzProg").style.width=p+"%";}

function goScreen(name,pct){
  const cur=wizard.querySelector(".screen.active");
  const next=wizard.querySelector('[data-screen="'+name+'"]');
  if(!next||cur===next)return;
  const h0=cur?cur.offsetHeight:0, h1=next.offsetHeight;
  wizard.style.height=h0+"px";
  if(cur)cur.classList.remove("active");
  next.classList.add("active");
  requestAnimationFrame(()=>{wizard.style.height=h1+"px";});
  clearTimeout(wizard._t);
  wizard._t=setTimeout(()=>{if(next.classList.contains("active"))wizard.style.height="auto";},420);
  if(pct!=null)setProgress(pct);
  document.getElementById("wzStep").textContent=stepLabels[name]||"";
}
function nav(to,pct){const cur=wizard.querySelector(".screen.active").dataset.screen;stack.push({s:cur,p:curPct});goScreen(to,pct);}
function back(){const prev=stack.pop();if(prev)goScreen(prev.s,prev.p);}
function restart(){stack=[];Object.keys(picked).forEach(k=>delete picked[k]);wizard.querySelectorAll(".opt-card.sel").forEach(o=>o.classList.remove("sel"));goScreen("q1",25);}

/* בחירה עם משוב קצר ואז מעבר */
function pick(el,then){el.classList.add("sel");setTimeout(()=>{then();el.classList.remove("sel");},180);}

function answerQ1(v,el){picked.q1={key:v,question:qText("q1"),answer:aText(el)};pick(el,()=>{
  if(v==="vehicle")nav("q2",55);
  else if(v==="property"||v==="both")nav("details",80);
  else if(v==="none")nav("q3",55);
});}
function answerQ2(v,el){picked.q2={key:v,question:qText("q2"),answer:aText(el)};pick(el,()=>{
  if(v==="full"){nav("no",100);}else{nav("details",80);}
});}
function answerQ3(v,el){picked.q3={key:v,question:qText("q3"),answer:aText(el)};pick(el,()=>{
  if(v==="yes"){nav("no",100);}else{nav("details",80);}
});}

/* ----- שליחת הליד ----- */
// נרמול טלפון: מקבל 05X..., +972..., 00972..., ומחזיר פורמט מקומי 0XXXXXXXXX
function normalizePhone(raw){
  let d=(raw||"").replace(/[^\d]/g,"");
  if(d.startsWith("00")) d=d.slice(2);
  if(d.startsWith("972")) d="0"+d.slice(3);
  return d;
}
function validPhone(v){return /^0(5\d|7\d|[2-489])\d{7}$/.test(normalizePhone(v));}
function validEmail(v){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test((v||"").trim());}
function submitLead(){
  const name=document.getElementById("name"),phone=document.getElementById("phone"),email=document.getElementById("email");
  let ok=true;
  if(name.value.trim().length<2){name.classList.add("invalid");document.getElementById("errName").classList.add("show");ok=false;}
  else{name.classList.remove("invalid");document.getElementById("errName").classList.remove("show");}
  if(!validPhone(phone.value)){phone.classList.add("invalid");document.getElementById("errPhone").classList.add("show");ok=false;}
  else{phone.classList.remove("invalid");document.getElementById("errPhone").classList.remove("show");}
  if(!validEmail(email.value)){email.classList.add("invalid");document.getElementById("errEmail").classList.add("show");ok=false;}
  else{email.classList.remove("invalid");document.getElementById("errEmail").classList.remove("show");}
  if(!ok)return;

  // בונים את התשובות לפי המסלול שנשאל בפועל — עם הטקסט המלא של השאלה והתשובה
  const qa={};
  if(picked.q1) qa[picked.q1.question]=picked.q1.answer;
  if(picked.q1&&picked.q1.key==="vehicle"&&picked.q2) qa[picked.q2.question]=picked.q2.answer;
  if(picked.q1&&picked.q1.key==="none"&&picked.q3) qa[picked.q3.question]=picked.q3.answer;

  // סיכום שאלון מוכן (שדה אחד קבוע) — שורה לכל שאלה: "שאלה ← תשובה"
  const qa_summary=Object.entries(qa).map(([q,a])=>`${q} ← ${a}`).join("\n");

  const lead=Object.assign({
    name:name.value.trim(),
    phone:normalizePhone(phone.value),
    email:email.value.trim(),
    time:new Date().toLocaleString("he-IL"),
    form_version:"2026-06-17-qa",
    qa_summary:qa_summary
  }, qa, tracking);

  // שליחה כ-form-urlencoded (כמו טופס רגיל): כל שדה מגיע בנפרד, בלי צורך ב-Parse JSON.
  // סוג תוכן זה נחשב "בקשה פשוטה" ולכן אינו מפעיל CORS preflight.
  const params=new URLSearchParams();
  Object.entries(lead).forEach(([k,v])=>{ if(v!==undefined&&v!==null&&String(v)!=="") params.append(k,String(v)); });
  const bodyStr=params.toString();
  CONFIG.webhooks.forEach(url=>{
    try{
      fetch(url,{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded;charset=UTF-8"},body:bodyStr,keepalive:true})
        .catch(e=>console.error("webhook failed:",url,e));
    }catch(e){console.error("webhook error:",url,e);}
  });
  console.log("LEAD:",lead);

  // אירוע Lead לפיקסל של מטא (פייסבוק) — נורה רק לאחר שליחה מוצלחת
  if(window.fbq) fbq('track','Lead');

  if(CONFIG.sendToWhatsApp){
    const qaLines=Object.entries(qa).map(([q,a])=>`${q} ${a}`).join("%0A");
    const msg=`היי, אני ${lead.name}. השארתי פרטים באתר זברה.%0Aטלפון: ${lead.phone}%0Aאימייל: ${lead.email}%0A${qaLines}`;
    const wa=document.getElementById("waConfirm");wa.href=`https://wa.me/${CONFIG.whatsapp}?text=${msg}`;wa.style.display="inline-block";
  }
  nav("done",100);
}

/* גובה דינמי בעת שינוי גודל חלון */
window.addEventListener("resize",()=>{const a=wizard.querySelector(".screen.active");if(a)wizard.style.height="auto";});

function scrollToForm(){document.getElementById("lead").scrollIntoView({behavior:"smooth",block:"start"});}

/* ----- מספרים מונפשים ----- */
function countUp(el){
  const target=+el.dataset.to,suf=el.dataset.suf||"",dur=1200,t0=performance.now();
  function step(t){const k=Math.min(1,(t-t0)/dur);el.textContent=Math.round(target*(1-Math.pow(1-k,3)))+suf;if(k<1)requestAnimationFrame(step);}
  requestAnimationFrame(step);
}
const countObs=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){countUp(e.target);countObs.unobserve(e.target);}});},{threshold:.4});
document.querySelectorAll(".bl .big[data-to]").forEach(el=>countObs.observe(el));

/* ----- reveal on scroll ----- */
const io=new IntersectionObserver((es)=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target);}});},{threshold:.12});
document.querySelectorAll(".reveal").forEach(el=>io.observe(el));


/* ----- מחשבון הלוואה (הערכה להמחשה בלבד) ----- */
(function(){
  const amount=document.getElementById("calcAmount");
  const term=document.getElementById("calcTerm");
  if(!amount||!term) return;
  const amountOut=document.getElementById("calcAmountOut");
  const termOut=document.getElementById("calcTermOut");
  const monthlyOut=document.getElementById("calcMonthly");
  const ANNUAL_RATE=0.09; // ריבית לדוגמה להמחשה בלבד
  const ils=n=>"\u20aa"+Math.round(n).toLocaleString("he-IL");
  function fillTrack(el){
    const pct=((el.value-el.min)/(el.max-el.min))*100;
    el.style.setProperty("--pct",pct+"%");
  }
  function calc(){
    const P=+amount.value, n=+term.value, r=ANNUAL_RATE/12;
    const m = r>0 ? P*r/(1-Math.pow(1+r,-n)) : P/n;
    amountOut.textContent=ils(P);
    termOut.textContent=n+" \u05d7\u05d5\u05d3\u05e9\u05d9\u05dd";
    monthlyOut.textContent=ils(m);
    fillTrack(amount); fillTrack(term);
  }
  amount.addEventListener("input",calc);
  term.addEventListener("input",calc);
  calc();
})();

/* ----- טופס המלצה: בחירת כוכבים + שליחה (עם honeypot) ----- */
let reviewRating = 5;
(function(){
  const stars = document.getElementById("rvStars");
  if(!stars) return;
  const btns = Array.from(stars.querySelectorAll(".star"));
  function paint(v){ btns.forEach(b=> b.classList.toggle("on", +b.dataset.v <= v)); }
  btns.forEach(b=>{
    b.addEventListener("click", ()=>{ reviewRating = +b.dataset.v; paint(reviewRating); });
    b.addEventListener("mouseenter", ()=> paint(+b.dataset.v));
  });
  stars.addEventListener("mouseleave", ()=> paint(reviewRating));
  paint(reviewRating); // ברירת מחדל 5
})();

function submitReview(){
  const nameEl=document.getElementById("rvName");
  const textEl=document.getElementById("rvText");
  const cityEl=document.getElementById("rvCity");
  const hp=document.getElementById("rvCompany");
  if(!nameEl||!textEl) return;

  // honeypot: אם השדה הנסתר מולא — כנראה בוט. עוצרים בשקט (מתנהגים כאילו הצליח).
  if(hp && hp.value.trim() !== ""){ showReviewThanks(); return; }

  let ok=true;
  if(nameEl.value.trim().length<2){nameEl.classList.add("invalid");document.getElementById("rvErrName").classList.add("show");ok=false;}
  else{nameEl.classList.remove("invalid");document.getElementById("rvErrName").classList.remove("show");}
  if(textEl.value.trim().length<5){textEl.classList.add("invalid");document.getElementById("rvErrText").classList.add("show");ok=false;}
  else{textEl.classList.remove("invalid");document.getElementById("rvErrText").classList.remove("show");}
  if(!ok) return;

  const review={
    name: nameEl.value.trim(),
    city: (cityEl?cityEl.value.trim():""),
    rating: String(reviewRating),
    text: textEl.value.trim(),
    time: new Date().toLocaleString("he-IL"),
    source: location.href
  };

  const url = CONFIG.reviewWebhook;
  if(url && url.indexOf("http")===0){
    const params=new URLSearchParams();
    Object.entries(review).forEach(([k,v])=>{ if(String(v)!=="") params.append(k,String(v)); });
    try{
      fetch(url,{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded;charset=UTF-8"},body:params.toString(),keepalive:true})
        .catch(e=>console.error("review webhook failed:",e));
    }catch(e){console.error("review webhook error:",e);}
  } else {
    console.warn("reviewWebhook not configured yet:", review);
  }
  showReviewThanks();
}
function showReviewThanks(){
  const f=document.getElementById("revForm"), t=document.getElementById("revThanks");
  if(f&&t){f.style.display="none";t.style.display="block";t.scrollIntoView({behavior:"smooth",block:"center"});}
}

/* ----- תפריט מובייל ----- */
(function(){
  const t=document.getElementById("navToggle"), n=document.getElementById("siteNav");
  if(t&&n){
    t.addEventListener("click",()=>{const o=n.classList.toggle("open");t.setAttribute("aria-expanded",o);});
    n.querySelectorAll("a").forEach(a=>a.addEventListener("click",()=>n.classList.remove("open")));
  }
})();

</script>
