---
const { path = "" } = Astro.props;
const links = [
  { href: "/", label: "בית" },
  { href: "/loans/kol-matara/", label: "הלוואה לכל מטרה" },
  { href: "/loans/baaley-asakim/", label: "לבעלי עסקים" },
  { href: "/loans/neged-rechev/", label: "כנגד רכב" },
  { href: "/blog/", label: "בלוג" },
  { href: "/reviews/", label: "המלצות" },
  { href: "/about/", label: "אודות" },
  { href: "/contact/", label: "צור קשר" },
];
const isActive = (href) => href === "/" ? path === "/" : path.startsWith(href);
---
<header class="site-header">
  <div class="wrap header-row">
    <a class="brand" href="/" aria-label="זברה"><img src="/images/logo.png" alt="זברה" width="120" height="46"></a>
    <nav class="site-nav" id="siteNav">
      {links.map((l) => <a href={l.href} class={isActive(l.href) ? "active" : ""}>{l.label}</a>)}
    </nav>
    <div class="header-cta">
      <a class="phone-link" id="hdrPhone" href="tel:0500000000">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        חייגו אלינו
      </a>
      <a class="btn" href="/#lead">בדקו התאמה</a>
      <button class="nav-toggle" id="navToggle" aria-label="תפריט" aria-expanded="false">&#9776;</button>
      <a class="hdr-call-m" id="hdrCallM" href="tel:0500000000" aria-label="חייגו אלינו">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    </div>
  </div>
</header>
