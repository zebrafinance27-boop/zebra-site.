---
// באנר הסכמה לעוגיות — חוסם את ה-Meta Pixel עד שהמשתמש מאשר.
// הטקסט המשפטי הוא ברירת מחדל סבירה; מומלץ לאשר את הנוסח המדויק מול גורם מוסמך.
---
<div id="zbCookie" class="zb-cookie" role="dialog" aria-live="polite"
     aria-label="הסכמה לשימוש בעוגיות" hidden>
  <div class="zb-cookie-card">
    <div class="zb-cookie-ico" aria-hidden="true">
      <span class="zb-stripes"><i></i><i></i><i></i></span>
      🍪
    </div>
    <div class="zb-cookie-body">
      <h3>רגע לפני שנמשיך</h3>
      <p>
        אנחנו משתמשים בעוגיות כדי שהאתר יעבוד חלק, לשיפור החוויה, ולמדידה.
        המשך הגלישה מהווה הסכמה לשימוש בעוגיות.
        <a href="/privacy/" class="zb-cookie-link">מדיניות הפרטיות</a>
      </p>
      <div class="zb-cookie-actions">
        <button type="button" class="zb-btn zb-btn-accept" id="zbCookieAccept">מסכים/ה</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var KEY = "zebra_cookie_consent";
    var el = document.getElementById("zbCookie");
    if (!el) return;

    var stored = null;
    try { stored = localStorage.getItem(KEY); } catch (e) {}

    // מציגים את הבאנר רק אם המשתמש עוד לא אישר
    if (stored !== "granted") {
      el.hidden = false;
      requestAnimationFrame(function () { el.classList.add("show"); });
    }

    var a = document.getElementById("zbCookieAccept");
    if (a) a.addEventListener("click", function () {
      try { localStorage.setItem(KEY, "granted"); } catch (e) {}
      el.classList.remove("show");
      setTimeout(function () { el.hidden = true; }, 350);
    });
  })();
</script>

<style>
  .zb-cookie {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 80;
    display: flex;
    justify-content: center;
    padding: 0 16px 18px;
    pointer-events: none;
  }
  .zb-cookie-card {
    pointer-events: auto;
    width: min(560px, 100%);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 20px;
    box-shadow: var(--shadow);
    padding: 20px 22px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
    transform: translateY(140%);
    opacity: 0;
    transition: transform .42s cubic-bezier(.16,1,.3,1), opacity .42s;
    border-top: 4px solid var(--green);
  }
  .zb-cookie.show .zb-cookie-card { transform: translateY(0); opacity: 1; }

  .zb-cookie-ico {
    position: relative;
    flex: none;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--tint);
    display: grid;
    place-items: center;
    font-size: 26px;
    overflow: hidden;
  }
  .zb-stripes {
    position: absolute;
    top: -6px; left: -10px;
    transform: rotate(-30deg);
    display: flex; flex-direction: column; gap: 5px;
    opacity: .25;
  }
  .zb-stripes i { display: block; width: 70px; height: 5px; border-radius: 4px; background: var(--ink); }

  .zb-cookie-body h3 { font-size: 1.12rem; font-weight: 800; margin-bottom: 4px; color: var(--ink); }
  .zb-cookie-body p { font-size: .94rem; color: var(--muted); line-height: 1.5; }
  .zb-cookie-link { color: var(--green-darker); font-weight: 600; text-decoration: underline; }

  .zb-cookie-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
  .zb-btn {
    font-family: inherit; font-weight: 600; font-size: .95rem;
    border: none; cursor: pointer; border-radius: 12px; padding: 11px 22px;
    transition: transform .15s, box-shadow .18s, background .18s;
  }
  .zb-btn-accept { background: var(--green); color: #fff; box-shadow: 0 12px 24px -12px rgba(95,168,51,.9); }
  .zb-btn-accept:hover { background: var(--green-deep); transform: translateY(-2px); }
  .zb-btn-reject { background: transparent; color: var(--green-darker); border: 1.6px solid var(--line); }
  .zb-btn-reject:hover { background: rgba(95,168,51,.08); border-color: var(--green); }

  @media (max-width: 520px) {
    .zb-cookie-card { flex-direction: column; gap: 12px; padding: 18px; }
    .zb-cookie-actions .zb-btn { flex: 1; text-align: center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .zb-cookie-card { transition: opacity .2s; transform: none; }
  }
</style>
