<section class="qualify" id="lead">
  <div class="wrap">
    <div class="qualify-head reveal">
      <h2>בדקו התאמה תוך 30 שניות</h2>
      <p>כמה שאלות קצרות — ונדע איך נוכל לעזור. בלי התחייבות.</p>
    </div>

    <div class="wz-card reveal">
      <div class="wz-top">
        <img class="wz-mini" src="/images/logo.png" alt="זברה">
        <div class="wz-track"><i id="wzProg" style="width:25%"></i></div>
        <span class="wz-step" id="wzStep">שאלה 1</span>
      </div>

      <div class="wizard" id="wizard">

        <!-- Q1 -->
        <div class="screen active" data-screen="q1">
          <p class="q-title">מה מתוך הבאים נמצא בבעלותך?</p>
          <p class="q-sub">נבדוק לפי זה איך נוכל להשיג לך מימון.</p>
          <div class="opts">
            <button class="opt-card" onclick="answerQ1('vehicle',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><path d="M5 16l1.4-4.4A2 2 0 0 1 8.3 10h7.4a2 2 0 0 1 1.9 1.6L19 16M4 16h16v3H4z" stroke-linejoin="round"/><circle cx="7.5" cy="19" r="1.4"/><circle cx="16.5" cy="19" r="1.4"/></svg></span>
              <span class="oc-label">רכב משנת 2012 ומעלה</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ1('both',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><path d="M3 10l4-3 4 3v6H3z" stroke-linejoin="round"/><path d="M13.5 18l.7-2.2h4.6L19.5 18M12.5 18h8v2.4h-8z" stroke-linejoin="round"/></svg></span>
              <span class="oc-label">רכב משנת 2012 ומעלה — וגם נכס</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ1('property',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><path d="M4 11l8-6 8 6v8a1 1 0 0 1-1 1h-4v-6H9v6H5a1 1 0 0 1-1-1z" stroke-linejoin="round"/></svg></span>
              <span class="oc-label">נכס (דירה / נכס מקרקעין)</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ1('none',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M6 6l12 12" stroke-linecap="round"/></svg></span>
              <span class="oc-label">אין ברשותי רכב או נכס</span><span class="oc-arr"></span>
            </button>
          </div>
        </div>

        <!-- Q2: vehicle status -->
        <div class="screen" data-screen="q2">
          <button class="wz-back" onclick="back()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>חזרה</button>
          <p class="q-title">מה מצב המימון על הרכב כיום?</p>
          <p class="q-sub">זה עוזר לנו לדעת על איזה סכום אפשר לדבר.</p>
          <div class="opts">
            <button class="opt-card" onclick="answerQ2('owned',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8.4 12.4l2.4 2.4 4.8-4.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="oc-label">הרכב בבעלותי המלאה (ללא מימון)</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ2('partial',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><path d="M19 5L5 19" stroke-linecap="round"/><circle cx="7.5" cy="7.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg></span>
              <span class="oc-label">מימון חלקי — עד 50% משווי הרכב</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ2('full',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3" stroke-linecap="round"/></svg></span>
              <span class="oc-label">מימון מלא על הרכב</span><span class="oc-arr"></span>
            </button>
          </div>
        </div>

        <!-- Q3: returns check -->
        <div class="screen" data-screen="q3">
          <button class="wz-back" onclick="back()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>חזרה</button>
          <p class="q-title">ב-3 השנים האחרונות — היו החזרות של צ׳קים או הוראות קבע?</p>
          <div class="opts">
            <button class="opt-card" onclick="answerQ3('no',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8.4 12.4l2.4 2.4 4.8-4.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
              <span class="oc-label">לא היו החזרות</span><span class="oc-arr"></span>
            </button>
            <button class="opt-card" onclick="answerQ3('yes',this)">
              <span class="oc-ic"><svg viewBox="0 0 24 24"><path d="M12 4l9 16H3z" stroke-linejoin="round"/><path d="M12 10v4M12 17v.01" stroke-linecap="round"/></svg></span>
              <span class="oc-label">כן, היו החזרות</span><span class="oc-arr"></span>
            </button>
          </div>
        </div>

        <!-- DETAILS -->
        <div class="screen" data-screen="details">
          <button class="wz-back" onclick="back()"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>חזרה</button>
          <p class="q-title">כמעט שם — לאן נחזור אליך?</p>
          <p class="q-sub">נציג מ'זברה' יחזור אליך עם הצעה מותאמת, בלי התחייבות.</p>
          <div class="field">
            <label for="name">שם מלא</label>
            <input type="text" id="name" autocomplete="name" placeholder="ישראל ישראלי">
            <div class="err" id="errName">נא להזין שם מלא</div>
          </div>
          <div class="field">
            <label for="phone">טלפון נייד</label>
            <input type="tel" id="phone" inputmode="tel" autocomplete="tel" placeholder="050-0000000 או +972..." dir="ltr">
            <div class="err" id="errPhone">נא להזין מספר נייד תקין</div>
          </div>
          <div class="field">
            <label for="email">אימייל</label>
            <input type="email" id="email" autocomplete="email" placeholder="name@example.com" dir="ltr">
            <div class="err" id="errEmail">נא להזין כתובת אימייל תקינה</div>
          </div>
          <button class="btn wz-submit" onclick="submitLead()">שליחת הפרטים</button>
          <p class="privacy-note">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            הפרטים שלכם נשמרים אצלנו בלבד ולא מועברים לאף גורם.
          </p>
        </div>

        <!-- DONE -->
        <div class="screen" data-screen="done">
          <div class="result">
            <div class="badge ok"><svg viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>תודה! קיבלנו את הפרטים</h3>
            <p>נציג מ'זברה' יחזור אליכם בהקדם עם הצעה מותאמת אישית.</p>
            <a class="btn" id="waConfirm" href="#" style="display:none">המשך שיחה ב-WhatsApp</a>
          </div>
        </div>

        <!-- NOT ELIGIBLE -->
        <div class="screen" data-screen="no">
          <div class="result">
            <div class="badge no"><svg viewBox="0 0 24 24"><path d="M12 7.5v6M12 16.8v.01" stroke-linecap="round"/></svg></div>
            <h3>תודה על העניין</h3>
            <p>על סמך התשובות, כרגע איננו יכולים להתקדם יחד. אם המצב ישתנה — נשמח שתחזרו אלינו.</p>
            <button class="btn btn-line" onclick="restart()">התחלה מחדש</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>