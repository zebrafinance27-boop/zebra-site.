---
import Base from "../layouts/Base.astro";
import LeadForm from "../components/LeadForm.astro";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    { "@type": "Question", name: "תוך כמה זמן מקבלים תשובה?", acceptedAnswer: { "@type": "Answer", text: "לרוב מקבלים תשובה ראשונית תוך דקות בודדות מרגע מילוי השאלון." } },
    { "@type": "Question", name: "מתי הכסף מגיע לחשבון?", acceptedAnswer: { "@type": "Answer", text: "לאחר אישור ההלוואה והשלמת המסמכים, הכסף מועבר לחשבון תוך עד 24 שעות." } },
    { "@type": "Question", name: "מהם תנאי ההחזר?", acceptedAnswer: { "@type": "Answer", text: "פריסה גמישה של עד 100 תשלומים, עם החזר חודשי שמתאים לתקציב." } },
    { "@type": "Question", name: "כמה עולה לבדוק התאמה?", acceptedAnswer: { "@type": "Answer", text: "בדיקת ההתאמה ללא עלות ובלי התחייבות. עובדים על בסיס הצלחה בלבד, בלי דמי פתיחת תיק ובלי עמלות מראש." } }
  ]
};
---
<Base>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />

<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-text reveal">
      <span class="eyebrow">הדרך הקלה להלוואה</span>
      <h1>צריכים מימון? אנחנו מתאימים לכם בדיוק את <span class="hl">ההלוואה הנכונה</span>.</h1>
      <p class="lede">הלוואות לכל מטרה, לבעלי עסקים, וכנגד הרכב — בלי למסור את המפתחות. אישור מהיר, ללא בירוקרטיה, והכסף בחשבון תוך 24 שעות.</p>
      <ul class="points">
        <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>תהליך קצר</li>
        <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>עד 100 תשלומים</li>
        <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>כסף תוך 24 שעות</li>
      </ul>
      <div class="hero-actions">
        <button class="btn" onclick="scrollToForm()">בדקו התאמה תוך 30 שניות</button>
        <a class="btn btn-line" id="heroCall" href="tel:0500000000">חייגו אלינו</a>
      </div>
      <div class="hero-trustline">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        ללא עלות ובלי התחייבות · עובדים על בסיס הצלחה בלבד
      </div>
    </div>

    <div class="hero-visual reveal">
      <div class="stripes"><span></span><span></span><span></span></div>
      <div class="spotlight"></div>
      <img class="hero-zebra" src="/images/zebra.webp" alt="זברה">
    </div>
  </div>
</section>

<LeadForm />

<div class="trust">
  <div class="wrap trust-row reveal">
    <div class="trust-item"><div class="ti-ico"><svg viewBox="0 0 24 24"><circle cx="12" cy="13" r="8"/><path d="M12 13V9M12 5V3M9 3h6" stroke-linecap="round"/></svg></div><h4>תשובה מהירה</h4><span>בדקות בודדות</span></div>
    <div class="trust-item"><div class="ti-ico"><svg viewBox="0 0 24 24"><rect x="5" y="3" width="14" height="18" rx="2"/><path d="M9 9l1.5 1.5L14 7M9 15h6" stroke-linecap="round" stroke-linejoin="round"/></svg></div><h4>תהליך פשוט</h4><span>100% אונליין</span></div>
    <div class="trust-item"><div class="ti-ico"><svg viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3" stroke-linecap="round"/></svg></div><h4>פרטיות מלאה</h4><span>שומרים על המידע שלך</span></div>
    <div class="trust-item"><div class="ti-ico"><svg viewBox="0 0 24 24"><circle cx="9" cy="8" r="3"/><path d="M3.5 20c0-3.2 2.6-5 5.5-5s5.5 1.8 5.5 5" stroke-linecap="round"/><circle cx="17.5" cy="9" r="2.2"/><path d="M16.5 15.2c2.6.1 4.5 1.6 4.5 4.4" stroke-linecap="round"/></svg></div><h4>ליווי אישי</h4><span>צוות מקצועי לצידך</span></div>
    <div class="trust-item"><div class="ti-ico"><svg viewBox="0 0 24 24"><path d="M12 3l2.4 5 5.6.5-4.2 3.7 1.3 5.5L12 20l-5.1 2.7 1.3-5.5L4 13.5l5.6-.5z" stroke-linejoin="round"/></svg></div><h4>פתרונות מותאמים</h4><span>לכל מטרה ובכל שלב</span></div>
  </div>
</div>

<section class="block">
  <div class="wrap">
    <div class="advocate reveal">
      <span class="eyebrow">למה זברה</span>
      <h2>אנחנו עובדים בשבילכם</h2>
      <p>זברה היא לא חברת מימון — אנחנו הגוף שמתווך בינך לבין המלווים, ועובד עבורך. אנחנו כאן כדי להילחם מול חברות המימון ולהשיג לך את ההלוואה המשתלמת ביותר.</p>
      <div class="adv-chips">
        <span><svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>מתווכים, לא מלווים</span>
        <span><svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>על בסיס הצלחה בלבד</span>
        <span><svg viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>בלי דמי פתיחת תיק או עמלות מראש</span>
      </div>
    </div>
  </div>
</section>

<section class="block">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">מה אנחנו עושים</span>
      <h2>מימון שמתאים בדיוק אליכם</h2>
      <p>שלושה מסלולים, מטרה אחת — להביא לכם את הכסף בתנאים הכי נוחים, מהר.</p>
    </div>
    <div class="cards">
      <div class="card reveal">
        <div class="c-ico"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8"/><path d="M12 8v8M9.5 14.5c0 1.1 1.1 1.8 2.5 1.8s2.5-.7 2.5-1.8-1.1-1.6-2.5-1.8-2.5-.7-2.5-1.8 1.1-1.8 2.5-1.8 2.5.7 2.5 1.8" stroke-linecap="round"/></svg></div>
        <h3>הלוואות לכל מטרה</h3>
        <p>שיפוץ, רכב, אירוע, איחוד הלוואות או כל צורך אחר.</p>
        <ul>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>פריסה גמישה עד 100 תשלומים</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>החזר חודשי מותאם לתקציב</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>אישור מהיר וללא בירוקרטיה</li>
        </ul>
      </div>
      <div class="card reveal">
        <div class="c-ico"><svg viewBox="0 0 24 24"><rect x="4" y="8" width="16" height="12" rx="2"/><path d="M9 8V6a3 3 0 0 1 6 0v2M4 13h16" stroke-linecap="round"/></svg></div>
        <h3>הלוואות לבעלי עסקים</h3>
        <p>הון חוזר, צמיחה או גישור על פערי תזרים.</p>
        <ul>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>מימון מהיר להמשך פעילות</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>מותאם לצרכים של העסק</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>ליווי אישי לאורך כל הדרך</li>
        </ul>
      </div>
      <div class="card reveal">
        <div class="c-ico"><svg viewBox="0 0 24 24"><path d="M5 16l1.5-5h11L19 16M3 16h18v3H3z" stroke-linejoin="round"/><circle cx="7.5" cy="19" r="1.5"/><circle cx="16.5" cy="19" r="1.5"/></svg></div>
        <h3>הלוואות כנגד הרכב</h3>
        <p>מקבלים מימון על בסיס שווי הרכב — בלי לוותר על הניידות.</p>
        <ul>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>הרכב והמפתחות נשארים אצלכם</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>גם עם מימון חלקי קיים</li>
          <li><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="12"/><path d="M7 12.5l3.2 3.2L17 8.8" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>סכום בהתאם לשווי הרכב</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="block" style="background:var(--paper);border-block:1px solid var(--line)">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">איך זה עובד</span>
      <h2>שלושה צעדים לכסף בחשבון</h2>
    </div>
    <div class="steps">
      <div class="stepc reveal"><div class="num">01</div><h3>בודקים התאמה</h3><p>עונים על השאלון הקצר ומשאירים פרטים — פחות מדקה, הכל אונליין.</p></div>
      <div class="stepc reveal"><div class="num">02</div><h3>מקבלים הצעה</h3><p>אנחנו בודקים ומחזירים לכם הצעה מותאמת אישית, מהר וברור.</p></div>
      <div class="stepc reveal"><div class="num">03</div><h3>הכסף בחשבון</h3><p>תוך עד 24 שעות, בפריסה שנוחה לכם. בלי בירוקרטיה.</p></div>
    </div>
  </div>
</section>

<section class="block">
  <div class="wrap">
    <div class="band reveal">
      <div class="stripe-corner"><span></span><span></span><span></span></div>
      <h2>השורה התחתונה</h2>
      <p class="band-sub">הלוואה טובה מתחילה בהחלטה נכונה.</p>
      <div class="band-grid">
        <div class="bl"><div class="big" data-to="24" data-suf=" שעות">24 שעות</div><p>הכסף אצלכם בחשבון</p></div>
        <div class="bl"><div class="big" data-to="100" data-suf="">100</div><p>תשלומים — פריסה גמישה</p></div>
        <div class="bl"><div class="big" data-to="100" data-suf="%">100%</div><p>אונליין, בלי לצאת מהבית</p></div>
        <div class="bl"><div class="big" data-to="0" data-suf="%">0%</div><p>סיכון — על בסיס הצלחה בלבד</p></div>
      </div>
    </div>
  </div>
</section>

<section class="block" style="background:var(--paper);border-block:1px solid var(--line)">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">שאלות נפוצות</span>
      <h2>כל מה שרציתם לדעת</h2>
    </div>
    <div class="faq reveal">
      <details class="faq-item"><summary>תוך כמה זמן מקבלים תשובה?<span class="fq-ic"></span></summary><div class="faq-a">לרוב מקבלים תשובה ראשונית תוך דקות בודדות מרגע מילוי השאלון. נציג חוזר אליכם עם הצעה מותאמת בהקדם.</div></details>
      <details class="faq-item"><summary>מתי הכסף מגיע לחשבון?<span class="fq-ic"></span></summary><div class="faq-a">לאחר אישור ההלוואה והשלמת המסמכים, הכסף מועבר לחשבון תוך עד 24 שעות.</div></details>
      <details class="faq-item"><summary>מהם תנאי ההחזר?<span class="fq-ic"></span></summary><div class="faq-a">אנחנו בונים יחד אתכם פריסה גמישה של עד 100 תשלומים, עם החזר חודשי שמתאים לתקציב שלכם.</div></details>
      <details class="faq-item"><summary>מה זה "הלוואה כנגד הרכב"?<span class="fq-ic"></span></summary><div class="faq-a">מקבלים מימון על בסיס שווי הרכב שבבעלותכם — בלי למסור את הרכב או את המפתחות, וממשיכים להשתמש בו כרגיל.</div></details>
      <details class="faq-item"><summary>כמה עולה לבדוק התאמה?<span class="fq-ic"></span></summary><div class="faq-a">בדיקת ההתאמה ללא עלות ובלי התחייבות. אנחנו עובדים על בסיס הצלחה בלבד — בלי דמי פתיחת תיק ובלי עמלות מראש.</div></details>
    </div>
  </div>
</section>

<section class="block">
  <div class="wrap">
    <div class="sec-head center reveal">
      <span class="eyebrow">לקוחות מספרים</span>
      <h2>אנשים שכבר קיבלו מענה</h2>
    </div>
    <div class="quotes">
      <div class="quote reveal"><div class="stars">★★★★★</div><p>"תהליך מהיר ופשוט, ליוו אותי בכל שלב. הכסף היה אצלי כבר למחרת."</p><div class="who">ד. כהן<span>תל אביב</span></div></div>
      <div class="quote reveal"><div class="stars">★★★★★</div><p>"קיבלתי מימון לעסק בלי כל הבירוקרטיה שהכרתי מהבנק. שירות אדיב ומקצועי."</p><div class="who">מ. לוי<span>חיפה</span></div></div>
      <div class="quote reveal"><div class="stars">★★★★★</div><p>"הלוואה כנגד הרכב והמשכתי לנסוע בו רגיל. בדיוק מה שהייתי צריך."</p><div class="who">ש. אברהם<span>באר שבע</span></div></div>
    </div>
  </div>
</section>

<section class="block final">
  <div class="wrap reveal">
    <h2>מוכנים להתחיל?</h2>
    <p>בדקו התאמה תוך 30 שניות — ונחזור אליכם עם ההצעה המתאימה לכם.</p>
    <button class="btn" onclick="scrollToForm()">לבדיקת התאמה</button>
  </div>
</section>
</Base>
